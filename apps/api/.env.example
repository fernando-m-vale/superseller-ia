PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/superseller
JWT_SECRET=change-me
CORS_ORIGIN=http://localhost:3000
SCHEDULER_SERVICE_TOKEN=           # Gerar: node -e "console.log(require('crypto').randomUUID())"
INTERNAL_API_URL=http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...    # Configurar após deploy no Stripe Dashboard
STRIPE_PRO_PRICE_MONTHLY=price_... # R$297/mês
STRIPE_PRO_PRICE_ANNUAL=price_...  # R$247/mês (anual)
STRIPE_TRIAL_DAYS=14

# App
APP_URL=https://app.superselleria.com.br

# Resend (emails transacionais)
RESEND_API_KEY=re_...
RESEND_FROM=SuperSeller IA <noreply@superselleria.com.br>

# Admin
ADMIN_SECRET=change-me-admin-secret   # JWT secret para autenticação admin
ADMIN_EMAIL=admin@superselleria.com.br
ADMIN_PASSWORD=change-me-admin-password
